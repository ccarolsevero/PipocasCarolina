    "db:admin": "node scripts/seed-admin.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^1.24.0",
