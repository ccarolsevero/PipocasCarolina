{
  "name": "pipocascarolina",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c magenta,cyan \"npm run server\" \"vite\"",
    "server": "node server/index.js",
    "build": "tsc -b && vite build",
    "start": "NODE_ENV=production node server/index.js",
